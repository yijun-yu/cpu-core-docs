{"config":{"lang":["zh"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u9996\u9875","text":""},{"location":"#welcome-to-mkdocs","title":"Welcome to MkDocs","text":"<p>For full documentation visit mkdocs.org.</p>"},{"location":"#commands","title":"Commands","text":"<ul> <li><code>mkdocs new [dir-name]</code> - Create a new project.</li> <li><code>mkdocs serve</code> - Start the live-reloading docs server.</li> <li><code>mkdocs build</code> - Build the documentation site.</li> <li><code>mkdocs -h</code> - Print help message and exit.</li> </ul>"},{"location":"#project-layout","title":"Project layout","text":"<pre><code>mkdocs.yml    # The configuration file.\ndocs/\n    index.md  # The documentation homepage.\n    ...       # Other markdown pages, images and other files.\n</code></pre>"},{"location":"01-overview/","title":"\u6982\u89c8","text":""},{"location":"01-overview/#_1","title":"\u6574\u4f53\u67b6\u6784\u6982\u89c8","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"01-overview/pipeline/","title":"\u4e03\u7ea7\u6d41\u6c34\u7ebf","text":""},{"location":"01-overview/pipeline/#_1","title":"\u4e03\u7ea7\u6d41\u6c34\u7ebf","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"02-fetch/","title":"IF \u53d6\u6307","text":""},{"location":"02-fetch/#if","title":"IF \u53d6\u6307\u7ea7","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"03-decode/","title":"ID \u8bd1\u7801","text":""},{"location":"03-decode/#id","title":"ID \u8bd1\u7801\u7ea7","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"04-issue/","title":"ISS \u53d1\u5c04","text":""},{"location":"04-issue/#iss","title":"ISS \u53d1\u5c04\u7ea7","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"05-execute/","title":"\u6982\u89c8","text":""},{"location":"05-execute/#ex","title":"EX \u6267\u884c\u7ea7","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"05-execute/alu/","title":"ALU","text":""},{"location":"05-execute/alu/#alu","title":"ALU","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"05-execute/branch/","title":"\u5206\u652f\u9884\u6d4b","text":""},{"location":"05-execute/branch/#branch_predictor","title":"\u5206\u652f\u9884\u6d4b\u5668 (Branch_Predictor)","text":""},{"location":"05-execute/branch/#_1","title":"\u6a21\u5757\u6982\u89c8","text":"<p>\u672c\u6a21\u5757\u5b9e\u73b0 2bit \u9971\u548c\u8ba1\u6570\u5668\u5206\u652f\u9884\u6d4b\uff0c\u5bf9\u5e94 RTL \u6587\u4ef6 <code>Branch_Predictor.v</code>\u3002</p> <ul> <li>\u4f4d\u4e8e\u6d41\u6c34\u7ebf\uff1aIF / ID \u9636\u6bb5\u8bfb\u53d6\uff0cEX \u9636\u6bb5\u66f4\u65b0</li> <li>\u9884\u6d4b\u7c92\u5ea6\uff1a\u6bcf\u6761\u5206\u652f\u6307\u4ee4\u4e00\u4e2a\u72b6\u6001</li> <li>\u9884\u6d4b\u7b56\u7565\uff1a4 \u6001\u9971\u548c\u8ba1\u6570\u5668\uff08\u5f3a\u4e0d\u8df3 / \u5f31\u4e0d\u8df3 / \u5f31\u8df3 / \u5f3a\u8df3\uff09</li> </ul>"},{"location":"05-execute/branch/#_2","title":"\u63a5\u53e3\u5b9a\u4e49","text":"\u4fe1\u53f7\u540d \u65b9\u5411 \u4f4d\u5bbd \u8bf4\u660e <code>clk</code> input 1 \u65f6\u949f <code>rst_n</code> input 1 \u4f4e\u6709\u6548\u590d\u4f4d <code>pc</code> input 32 \u5f53\u524d PC\uff0c\u7528\u4e8e\u7d22\u5f15\u9884\u6d4b\u8868 <code>branch_taken_actual</code> input 1 EX \u7ea7\u53cd\u9988\u7684\u5b9e\u9645\u8df3\u8f6c\u7ed3\u679c <code>predict_taken</code> output 1 \u9884\u6d4b\u7ed3\u679c\uff081=\u8df3\uff0c0=\u4e0d\u8df3\uff09"},{"location":"05-execute/branch/#_3","title":"\u8bbe\u8ba1\u601d\u8def","text":"<p>2bit \u9971\u548c\u8ba1\u6570\u5668\u7ef4\u62a4\u56db\u4e2a\u72b6\u6001\uff1a</p> \u72b6\u6001 \u542b\u4e49 \u9884\u6d4b <code>00</code> \u5f3a\u4e0d\u8df3 \u4e0d\u8df3 <code>01</code> \u5f31\u4e0d\u8df3 \u4e0d\u8df3 <code>10</code> \u5f31\u8df3 \u8df3 <code>11</code> \u5f3a\u8df3 \u8df3 <p>\u5b9e\u9645\u8df3\u8f6c\u65f6\u72b6\u6001\u5411 <code>11</code> \u79fb\u52a8\uff0c\u5b9e\u9645\u4e0d\u8df3\u65f6\u72b6\u6001\u5411 <code>00</code> \u79fb\u52a8\u3002</p>"},{"location":"05-execute/branch/#_4","title":"\u5173\u952e\u4ee3\u7801","text":"<pre><code>always @(posedge clk or negedge rst_n) begin\n    if (!rst_n) begin\n        state &lt;= 2'b01;  // \u590d\u4f4d\u5230\u5f31\u4e0d\u8df3\n    end else if (update_en) begin\n        case (state)\n            2'b00: state &lt;= branch_taken_actual ? 2'b01 : 2'b00;\n            2'b01: state &lt;= branch_taken_actual ? 2'b10 : 2'b00;\n            2'b10: state &lt;= branch_taken_actual ? 2'b11 : 2'b01;\n            2'b11: state &lt;= branch_taken_actual ? 2'b11 : 2'b10;\n        endcase\n    end\nend\n</code></pre>"},{"location":"05-execute/branch/#_5","title":"\u8bbe\u8ba1\u51b3\u7b56","text":"<p>\u4e3a\u4ec0\u4e48\u9009 2bit \u800c\u4e0d\u662f 1bit</p> <p>1bit \u9884\u6d4b\u5668\u5728\u5faa\u73af\u8fb9\u754c\u4f1a\u8fde\u7eed miss \u4e24\u6b21\uff08\u6700\u540e\u4e00\u6b21\u4e0d\u8df3 + \u4e0b\u6b21\u7b2c\u4e00\u6b21\u8df3\uff09\u3002 2bit \u5728\u540c\u6837\u573a\u666f\u53ea miss \u4e00\u6b21\uff0c\u5bf9\u77ed\u5faa\u73af\u573a\u666f\u547d\u4e2d\u7387\u63d0\u5347\u663e\u8457\uff0c \u8fd9\u4e5f\u662f\u5de5\u4e1a\u754c BHT \u7684\u6700\u4f4e\u57fa\u7ebf\u3002</p> <p>\u4e3a\u4ec0\u4e48\u590d\u4f4d\u5230\u5f31\u4e0d\u8df3 (01)</p> <p>\u51b7\u542f\u52a8\u72b6\u6001\u5bf9\u77ed\u7a0b\u5e8f\u5f71\u54cd\u8f83\u5927\u3002\u9009 01 \u800c\u975e 00 \u7684\u597d\u5904\u662f\uff1a \u4e00\u6b21\u6b63\u786e\u7684\u8df3\u8f6c\u5c31\u80fd\u5207\u5230\"\u8df3\"\u4fa7\uff0c\u53cd\u5e94\u66f4\u5feb\u3002 \u9009 01 \u800c\u975e 10 \u662f\u56e0\u4e3a RISC-V \u7a0b\u5e8f\u4e2d\u6761\u4ef6\u5206\u652f\u603b\u4f53\u4e0d\u8df3\u7684\u6bd4\u4f8b\u7565\u9ad8\u3002</p>"},{"location":"05-execute/branch/#_6","title":"\u8e29\u8fc7\u7684\u5751","text":"<p>\u5751 1\uff1a\u590d\u4f4d\u72b6\u6001\u673a\u9519\u4e71</p> <p>\u521d\u7248\u6ca1\u628a\u590d\u4f4d\u4fe1\u53f7\u540c\u6b65\u5230 always \u5757\u91cc\uff0c \u5bfc\u81f4\u51b7\u542f\u52a8\u65f6 <code>state</code> \u662f X\uff0c\u4eff\u771f\u6ce2\u5f62\u4e0a\u9884\u6d4b\u7ed3\u679c\u4e0d\u7a33\u5b9a\u3002</p> <p>\u4fee\u590d\uff1a\u628a <code>negedge rst_n</code> \u52a0\u8fdb\u654f\u611f\u5217\u8868\uff0c\u5e76\u5728 if \u5206\u652f\u91cc\u663e\u5f0f\u8d4b\u521d\u503c\u3002</p> <p>\u5751 2\uff1a\u9884\u6d4b\u66f4\u65b0\u65f6\u673a</p> <p>\u6700\u65e9\u628a\u66f4\u65b0\u903b\u8f91\u653e\u5728 IF \u7ea7\uff0c\u4f46 EX \u7ea7\u624d\u80fd\u5f97\u5230\u771f\u5b9e\u8df3\u8f6c\u7ed3\u679c\uff0c \u5bfc\u81f4\u72b6\u6001\u673a\u7528\"\u8fd8\u6ca1\u786e\u8ba4\"\u7684\u9884\u6d4b\u503c\u81ea\u6211\u66f4\u65b0\uff0c\u547d\u4e2d\u7387\u53cd\u800c\u4e0b\u964d\u3002</p> <p>\u4fee\u590d\uff1a\u9884\u6d4b\u5728 IF \u8bfb\u51fa\uff0c\u66f4\u65b0\u5ef6\u8fdf\u5230 EX \u7ea7\u53cd\u9988\u56de\u6765\u540e\u518d\u5199\u5165\u3002</p>"},{"location":"05-execute/branch/#_7","title":"\u76f8\u5173\u6a21\u5757","text":"<ul> <li>Branch_Unit\uff1a\u5b9e\u9645\u8ba1\u7b97\u5206\u652f\u6761\u4ef6</li> <li>IF_ID_Reg\uff1a\u628a\u9884\u6d4b\u7ed3\u679c\u4f20\u5230\u4e0b\u4e00\u7ea7</li> <li>Hazard_Detection\uff1a\u9884\u6d4b\u9519\u8bef\u65f6\u6e05\u6d41\u6c34\u7ebf</li> </ul>"},{"location":"05-execute/muldiv/","title":"\u4e58\u9664\u6cd5","text":""},{"location":"05-execute/muldiv/#_1","title":"\u4e58\u9664\u6cd5\u5355\u5143","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"05-execute/zbb/","title":"Zbb \u6269\u5c55","text":""},{"location":"05-execute/zbb/#zbb","title":"Zbb \u6269\u5c55","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"06-memory/","title":"MEM \u8bbf\u5b58","text":""},{"location":"06-memory/#mem","title":"MEM \u8bbf\u5b58\u7ea7","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"07-writeback/","title":"WB \u5199\u56de","text":""},{"location":"07-writeback/#wb","title":"WB \u5199\u56de\u7ea7","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"08-control/","title":"\u6982\u89c8","text":""},{"location":"08-control/#_1","title":"\u63a7\u5236\u903b\u8f91\u6982\u89c8","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"08-control/csr/","title":"CSR \u4e0e\u9677\u9631","text":""},{"location":"08-control/csr/#csr","title":"CSR \u4e0e\u9677\u9631","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"08-control/forward/","title":"\u524d\u9012\u5355\u5143","text":""},{"location":"08-control/forward/#_1","title":"\u524d\u9012\u5355\u5143","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"08-control/hazard/","title":"\u5192\u9669\u68c0\u6d4b","text":""},{"location":"08-control/hazard/#_1","title":"\u5192\u9669\u68c0\u6d4b","text":"<p>\u5f85\u7f16\u5199\u3002</p>"},{"location":"09-lessons/","title":"\u8e29\u5751\u8bb0\u5f55","text":""}]}
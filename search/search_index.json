{"config":{"lang":["zh"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u9996\u9875","text":""},{"location":"#welcome-to-mkdocs","title":"Welcome to MkDocs","text":"<p>For full documentation visit mkdocs.org.</p>"},{"location":"#commands","title":"Commands","text":"<ul> <li><code>mkdocs new [dir-name]</code> - Create a new project.</li> <li><code>mkdocs serve</code> - Start the live-reloading docs server.</li> <li><code>mkdocs build</code> - Build the documentation site.</li> <li><code>mkdocs -h</code> - Print help message and exit.</li> </ul>"},{"location":"#project-layout","title":"Project layout","text":"<pre><code>mkdocs.yml    # The configuration file.\ndocs/\n    index.md  # The documentation homepage.\n    ...       # Other markdown pages, images and other files.\n</code></pre>"},{"location":"branch-prediction/gshare/","title":"GShare","text":""},{"location":"branch-prediction/gshare/#gshare","title":"GShare","text":"<p>\u5f85\u8865\u5145</p> <p>\u672c\u8282\u89c4\u5212\u5185\u5bb9\uff1aGShare \u9884\u6d4b\u539f\u7406\uff08\u5168\u5c40\u5386\u53f2\u5bc4\u5b58\u5668 GHR \u4e0e PC \u5f02\u6216\u7d22\u5f15 PHT\uff09\u3001 \u4e0e 2bit \u9971\u548c\u8ba1\u6570\u5668\u7684\u5bf9\u6bd4\u3001\u522b\u540d\uff08aliasing\uff09\u95ee\u9898\u3001GHR \u4f4d\u5bbd\u9009\u62e9\u3001 \u9884\u6d4b\u9519\u8bef\u65f6 GHR \u7684\u6062\u590d\u3001RTL \u63a5\u53e3\u4e0e\u5173\u952e\u4ee3\u7801\u3002</p>"},{"location":"branch-prediction/two-bit-saturating-counter/","title":"2bit \u9971\u548c\u8ba1\u6570\u5668","text":""},{"location":"branch-prediction/two-bit-saturating-counter/#2bit","title":"2bit \u9971\u548c\u8ba1\u6570\u5668","text":""},{"location":"branch-prediction/two-bit-saturating-counter/#_1","title":"\u6a21\u5757\u6982\u89c8","text":"<p>\u672c\u6a21\u5757\u5b9e\u73b0 2bit \u9971\u548c\u8ba1\u6570\u5668\u5206\u652f\u9884\u6d4b\uff0c\u5bf9\u5e94 RTL \u6587\u4ef6 <code>Branch_Predictor.v</code>\u3002</p> <ul> <li>\u4f4d\u4e8e\u6d41\u6c34\u7ebf\uff1aIF / ID \u9636\u6bb5\u8bfb\u53d6\uff0cEX \u9636\u6bb5\u66f4\u65b0</li> <li>\u9884\u6d4b\u7c92\u5ea6\uff1a\u6bcf\u6761\u5206\u652f\u6307\u4ee4\u4e00\u4e2a\u72b6\u6001</li> <li>\u9884\u6d4b\u7b56\u7565\uff1a4 \u6001\u9971\u548c\u8ba1\u6570\u5668\uff08\u5f3a\u4e0d\u8df3 / \u5f31\u4e0d\u8df3 / \u5f31\u8df3 / \u5f3a\u8df3\uff09</li> </ul>"},{"location":"branch-prediction/two-bit-saturating-counter/#_2","title":"\u63a5\u53e3\u5b9a\u4e49","text":"\u4fe1\u53f7\u540d \u65b9\u5411 \u4f4d\u5bbd \u8bf4\u660e <code>clk</code> input 1 \u65f6\u949f <code>rst_n</code> input 1 \u4f4e\u6709\u6548\u590d\u4f4d <code>pc</code> input 32 \u5f53\u524d PC\uff0c\u7528\u4e8e\u7d22\u5f15\u9884\u6d4b\u8868 <code>branch_taken_actual</code> input 1 EX \u7ea7\u53cd\u9988\u7684\u5b9e\u9645\u8df3\u8f6c\u7ed3\u679c <code>predict_taken</code> output 1 \u9884\u6d4b\u7ed3\u679c\uff081=\u8df3\uff0c0=\u4e0d\u8df3\uff09"},{"location":"branch-prediction/two-bit-saturating-counter/#_3","title":"\u8bbe\u8ba1\u601d\u8def","text":"<p>2bit \u9971\u548c\u8ba1\u6570\u5668\u7ef4\u62a4\u56db\u4e2a\u72b6\u6001\uff1a</p> \u72b6\u6001 \u542b\u4e49 \u9884\u6d4b <code>00</code> \u5f3a\u4e0d\u8df3 \u4e0d\u8df3 <code>01</code> \u5f31\u4e0d\u8df3 \u4e0d\u8df3 <code>10</code> \u5f31\u8df3 \u8df3 <code>11</code> \u5f3a\u8df3 \u8df3 <p>\u5b9e\u9645\u8df3\u8f6c\u65f6\u72b6\u6001\u5411 <code>11</code> \u79fb\u52a8\uff0c\u5b9e\u9645\u4e0d\u8df3\u65f6\u72b6\u6001\u5411 <code>00</code> \u79fb\u52a8\u3002</p>"},{"location":"branch-prediction/two-bit-saturating-counter/#_4","title":"\u5173\u952e\u4ee3\u7801","text":"<pre><code>always @(posedge clk or negedge rst_n) begin\n    if (!rst_n) begin\n        state &lt;= 2'b01;  // \u590d\u4f4d\u5230\u5f31\u4e0d\u8df3\n    end else if (update_en) begin\n        case (state)\n            2'b00: state &lt;= branch_taken_actual ? 2'b01 : 2'b00;\n            2'b01: state &lt;= branch_taken_actual ? 2'b10 : 2'b00;\n            2'b10: state &lt;= branch_taken_actual ? 2'b11 : 2'b01;\n            2'b11: state &lt;= branch_taken_actual ? 2'b11 : 2'b10;\n        endcase\n    end\nend\n</code></pre>"},{"location":"branch-prediction/two-bit-saturating-counter/#_5","title":"\u8bbe\u8ba1\u51b3\u7b56","text":"<p>\u4e3a\u4ec0\u4e48\u9009 2bit \u800c\u4e0d\u662f 1bit</p> <p>1bit \u9884\u6d4b\u5668\u5728\u5faa\u73af\u8fb9\u754c\u4f1a\u8fde\u7eed miss \u4e24\u6b21\uff08\u6700\u540e\u4e00\u6b21\u4e0d\u8df3 + \u4e0b\u6b21\u7b2c\u4e00\u6b21\u8df3\uff09\u3002 2bit \u5728\u540c\u6837\u573a\u666f\u53ea miss \u4e00\u6b21\uff0c\u5bf9\u77ed\u5faa\u73af\u573a\u666f\u547d\u4e2d\u7387\u63d0\u5347\u663e\u8457\uff0c \u8fd9\u4e5f\u662f\u5de5\u4e1a\u754c BHT \u7684\u6700\u4f4e\u57fa\u7ebf\u3002</p> <p>\u4e3a\u4ec0\u4e48\u590d\u4f4d\u5230\u5f31\u4e0d\u8df3 (01)</p> <p>\u51b7\u542f\u52a8\u72b6\u6001\u5bf9\u77ed\u7a0b\u5e8f\u5f71\u54cd\u8f83\u5927\u3002\u9009 01 \u800c\u975e 00 \u7684\u597d\u5904\u662f\uff1a \u4e00\u6b21\u6b63\u786e\u7684\u8df3\u8f6c\u5c31\u80fd\u5207\u5230\u201c\u8df3\u201d\u4fa7\uff0c\u53cd\u5e94\u66f4\u5feb\u3002 \u9009 01 \u800c\u975e 10 \u662f\u56e0\u4e3a RISC-V \u7a0b\u5e8f\u4e2d\u6761\u4ef6\u5206\u652f\u603b\u4f53\u4e0d\u8df3\u7684\u6bd4\u4f8b\u7565\u9ad8\u3002</p>"},{"location":"branch-prediction/two-bit-saturating-counter/#_6","title":"\u8e29\u8fc7\u7684\u5751","text":"<p>\u5751 1\uff1a\u590d\u4f4d\u72b6\u6001\u673a\u9519\u4e71</p> <p>\u521d\u7248\u6ca1\u628a\u590d\u4f4d\u4fe1\u53f7\u540c\u6b65\u5230 always \u5757\u91cc\uff0c \u5bfc\u81f4\u51b7\u542f\u52a8\u65f6 <code>state</code> \u662f X\uff0c\u4eff\u771f\u6ce2\u5f62\u4e0a\u9884\u6d4b\u7ed3\u679c\u4e0d\u7a33\u5b9a\u3002</p> <p>\u4fee\u590d\uff1a\u628a <code>negedge rst_n</code> \u52a0\u8fdb\u654f\u611f\u5217\u8868\uff0c\u5e76\u5728 if \u5206\u652f\u91cc\u663e\u5f0f\u8d4b\u521d\u503c\u3002</p> <p>\u5751 2\uff1a\u9884\u6d4b\u66f4\u65b0\u65f6\u673a</p> <p>\u6700\u65e9\u628a\u66f4\u65b0\u903b\u8f91\u653e\u5728 IF \u7ea7\uff0c\u4f46 EX \u7ea7\u624d\u80fd\u5f97\u5230\u771f\u5b9e\u8df3\u8f6c\u7ed3\u679c\uff0c \u5bfc\u81f4\u72b6\u6001\u673a\u7528\u201c\u8fd8\u6ca1\u786e\u8ba4\u201d\u7684\u9884\u6d4b\u503c\u81ea\u6211\u66f4\u65b0\uff0c\u547d\u4e2d\u7387\u53cd\u800c\u4e0b\u964d\u3002</p> <p>\u4fee\u590d\uff1a\u9884\u6d4b\u5728 IF \u8bfb\u51fa\uff0c\u66f4\u65b0\u5ef6\u8fdf\u5230 EX \u7ea7\u53cd\u9988\u56de\u6765\u540e\u518d\u5199\u5165\u3002</p>"},{"location":"branch-prediction/two-bit-saturating-counter/#_7","title":"\u76f8\u5173\u6a21\u5757","text":"<ul> <li>Branch_Unit\uff1a\u5728 EX \u7ea7\u5b9e\u9645\u8ba1\u7b97\u5206\u652f\u6761\u4ef6\uff0c\u7ed9\u51fa <code>branch_taken_actual</code> \u53cd\u9988</li> <li>IF_ID_Reg\uff1a\u628a\u9884\u6d4b\u7ed3\u679c\u968f\u6307\u4ee4\u4f20\u5230\u4e0b\u4e00\u7ea7\uff08\u8be6\u89c1 \u6d41\u6c34\u7ebf\uff09</li> <li>Hazard_Detection\uff1a\u9884\u6d4b\u9519\u8bef\u65f6\u6e05\u6d41\u6c34\u7ebf\uff08\u8be6\u89c1 \u6d41\u6c34\u7ebf\uff09</li> </ul>"},{"location":"cache/","title":"Cache","text":""},{"location":"cache/#cache","title":"Cache","text":"<p>\u5f85\u8865\u5145</p> <p>\u672c\u7ae0\u89c4\u5212\u5185\u5bb9\uff1aCache \u57fa\u672c\u539f\u7406\u3001\u6620\u5c04\u65b9\u5f0f\uff08\u76f4\u63a5 / \u7ec4\u76f8\u8054\uff09\u3001\u66ff\u6362\u7b56\u7565\u3001\u5199\u7b56\u7565\u3001\u4e0e\u6d41\u6c34\u7ebf\u8bbf\u5b58\u7ea7\u7684\u96c6\u6210\u3002</p>"},{"location":"env/","title":"\u73af\u5883\u4e0e\u8f6f\u4ef6","text":""},{"location":"env/#_1","title":"\u73af\u5883\u4e0e\u8f6f\u4ef6","text":"<p>\u5f85\u8865\u5145</p> <p>\u672c\u7ae0\u89c4\u5212\u5185\u5bb9\uff1a\u5f00\u53d1\u73af\u5883\u642d\u5efa\u3001\u5de5\u5177\u94fe\uff08\u7f16\u8bd1\u5668 / \u4eff\u771f\u5668 / \u7efc\u5408\u5de5\u5177\uff09\u3001\u4f9d\u8d56\u8f6f\u4ef6\u4e0e\u7248\u672c\u3001\u5de5\u7a0b\u76ee\u5f55\u7ed3\u6784\u4e0e\u6784\u5efa\u6d41\u7a0b\u3002</p>"},{"location":"env/#iverilog","title":"iverilog","text":"<p>\u7ec8\u7aef\u8f93\u5165\uff1a<code>iverilog -o sim *.v</code></p> <p><code>*.v</code>\u8868\u793a\u6240\u6709 .v \u6587\u4ef6</p>"},{"location":"env/#verilator","title":"verilator","text":"<p>\u521b\u5efaMakefile\u6587\u4ef6 </p><pre><code>VFLAGS = --binary -j 0 --top-module tb_Core_top --timing \\\n\u00a0 \u00a0 \u00a0 \u00a0 \u00a0-Wno-WIDTH -Wno-CASEINCOMPLETE -Wno-UNOPTFLAT -Wno-LATCH \\\n\u00a0 \u00a0 \u00a0 \u00a0 \u00a0-Wno-MULTIDRIVEN -Wno-UNUSED -Wno-PINMISSING -Wno-IMPLICIT \\\n\u00a0 \u00a0 \u00a0 \u00a0 \u00a0-Wno-INITIALDLY -Wno-BLKANDNBLK -Wno-CMPCONST -Wno-fatal\n\nrun:\n\u00a0 \u00a0 verilator $(VFLAGS) *.v\n\u00a0 \u00a0 ./obj_dir/Vtb_Core_top\n\nclean:\n\u00a0 \u00a0 rm -rf obj_dir\n</code></pre><p></p> <p>\u7f29\u8fdb\u5fc5\u987b\u7528 Tab</p> <p><code>run:</code> / <code>clean:</code> \u4e0b\u9762\u7684\u547d\u4ee4\u884c\u5fc5\u987b\u7528 Tab \u7f29\u8fdb\uff0c\u4e0d\u80fd\u7528\u7a7a\u683c\uff0c \u5426\u5219\u6267\u884c <code>make</code> \u4f1a\u62a5 <code>*** missing separator. Stop.</code>\u3002</p> <p>\u8dd1\u4eff\u771f\u65f6\uff0c\u7ec8\u7aef\u8f93\u5165<code>make run</code> \u5220\u9664\u4eff\u771f\u6587\u4ef6\uff0c\u7ec8\u7aef\u8f93\u5165<code>make clean</code></p>"},{"location":"pipeline/","title":"\u6d41\u6c34\u7ebf","text":""},{"location":"pipeline/#_1","title":"\u6d41\u6c34\u7ebf","text":"<p>\u5f85\u8865\u5145</p> <p>\u672c\u7ae0\u89c4\u5212\u5185\u5bb9\uff1a\u6d41\u6c34\u7ebf\u5206\u7ea7\u3001\u6d41\u6c34\u7ebf\u5bc4\u5b58\u5668\u3001\u6570\u636e\u5192\u9669\u4e0e\u524d\u9012\u3001\u63a7\u5236\u5192\u9669\u4e0e\u505c\u987f\u3001\u7ed3\u6784\u5192\u9669\u7684\u5904\u7406\u3002</p>"},{"location":"single-cycle/alu/","title":"ALU","text":""},{"location":"single-cycle/alu/#alu","title":"ALU","text":"<p>\u5f85\u8865\u5145</p> <p>\u89c4\u5212\u5185\u5bb9\uff1a\u529f\u80fd\u6982\u89c8\uff08\u8fd0\u7b97\u7c7b\u578b\uff09\u3001\u63a5\u53e3\u5b9a\u4e49\u3001\u8fd0\u7b97\u9009\u62e9\u7f16\u7801\u3001\u5173\u952e\u4ee3\u7801\u3001\u4e0e ALU_Control \u7684\u914d\u5408\u3002</p>"},{"location":"single-cycle/alu_control/","title":"ALU_Control","text":""},{"location":"single-cycle/alu_control/#alu_control","title":"ALU_Control","text":"<p>\u5f85\u8865\u5145</p> <p>\u89c4\u5212\u5185\u5bb9\uff1a\u4f5c\u7528\uff08\u7531 ALUOp + funct \u5b57\u6bb5\u8bd1\u51fa ALU \u63a7\u5236\u4fe1\u53f7\uff09\u3001\u63a5\u53e3\u5b9a\u4e49\u3001\u771f\u503c\u8868\u3001\u5173\u952e\u4ee3\u7801\u3002</p>"},{"location":"single-cycle/architecture/","title":"\u603b\u4f53\u67b6\u6784\u56fe","text":""},{"location":"single-cycle/architecture/#_1","title":"\u603b\u4f53\u67b6\u6784\u56fe","text":"<p>\u5f85\u8865\u5145</p> <p>\u89c4\u5212\u5185\u5bb9\uff1a\u5355\u5468\u671f CPU \u9876\u5c42\u7ed3\u6784\u6846\u56fe\u3001\u5404\u6a21\u5757\uff08PC / RegFile / ALU / Control_Unit / ImmGen \u7b49\uff09\u7684\u8fde\u63a5\u5173\u7cfb\u4e0e\u8bf4\u660e\u3002</p>"},{"location":"single-cycle/control_unit/","title":"Control_Unit","text":""},{"location":"single-cycle/control_unit/#control_unit","title":"Control_Unit","text":"<p>\u5f85\u8865\u5145</p> <p>\u89c4\u5212\u5185\u5bb9\uff1a\u7531 opcode \u751f\u6210\u5404\u8def\u63a7\u5236\u4fe1\u53f7\uff08RegWrite / MemRead / MemWrite / Branch / ALUSrc / ALUOp \u7b49\uff09\u3001\u63a5\u53e3\u5b9a\u4e49\u3001\u63a7\u5236\u4fe1\u53f7\u771f\u503c\u8868\u3001\u5173\u952e\u4ee3\u7801\u3002</p>"},{"location":"single-cycle/datapath/","title":"\u6570\u636e\u901a\u8def\u56fe","text":""},{"location":"single-cycle/datapath/#_1","title":"\u6570\u636e\u901a\u8def\u56fe","text":"<p>\u5f85\u8865\u5145</p> <p>\u89c4\u5212\u5185\u5bb9\uff1a\u5355\u5468\u671f\u6570\u636e\u901a\u8def\u56fe\u3001\u5178\u578b\u6307\u4ee4\uff08R \u578b / I \u578b / load / store / branch\uff09\u5728\u901a\u8def\u4e0a\u7684\u6570\u636e\u6d41\u8d70\u5411\u3002</p>"},{"location":"single-cycle/immgen/","title":"ImmGen","text":""},{"location":"single-cycle/immgen/#immgen","title":"ImmGen","text":"<p>\u5f85\u8865\u5145</p> <p>\u89c4\u5212\u5185\u5bb9\uff1a\u7acb\u5373\u6570\u751f\u6210\uff08I/S/B/U/J \u5404\u578b\u7684\u62fc\u63a5\u4e0e\u7b26\u53f7\u6269\u5c55\uff09\u3001\u63a5\u53e3\u5b9a\u4e49\u3001\u5404\u6307\u4ee4\u683c\u5f0f\u7acb\u5373\u6570\u5e03\u5c40\u3001\u5173\u952e\u4ee3\u7801\u3002</p>"},{"location":"single-cycle/pc/","title":"PC","text":""},{"location":"single-cycle/pc/#pc","title":"PC","text":"<p>\u5f85\u8865\u5145</p> <p>\u89c4\u5212\u5185\u5bb9\uff1a\u7a0b\u5e8f\u8ba1\u6570\u5668\uff08PC+4 / \u5206\u652f\u76ee\u6807 / \u8df3\u8f6c\u76ee\u6807\u9009\u62e9\uff09\u3001\u63a5\u53e3\u5b9a\u4e49\u3001\u590d\u4f4d\u503c\u3001\u5173\u952e\u4ee3\u7801\u3002</p>"},{"location":"single-cycle/regfile/","title":"RegFile","text":""},{"location":"single-cycle/regfile/#regfile","title":"RegFile","text":"<p>\u5f85\u8865\u5145</p> <p>\u89c4\u5212\u5185\u5bb9\uff1a32\u00d732 \u5bc4\u5b58\u5668\u5806\uff08\u53cc\u8bfb\u5355\u5199\u3001x0 \u6052\u96f6\uff09\u3001\u63a5\u53e3\u5b9a\u4e49\u3001\u8bfb\u5199\u65f6\u5e8f\u3001\u5173\u952e\u4ee3\u7801\u3002</p>"},{"location":"superscalar/","title":"\u591a\u53d1\u5c04","text":""},{"location":"superscalar/#_1","title":"\u591a\u53d1\u5c04","text":"<p>\u5f85\u8865\u5145</p> <p>\u672c\u7ae0\u89c4\u5212\u5185\u5bb9\uff1a\u591a\u53d1\u5c04\u7684\u52a8\u673a\u3001\u53cc\u53d1\u5c04\u6570\u636e\u901a\u8def\u3001\u53d1\u5c04\u903b\u8f91\u4e0e\u76f8\u5173\u6027\u68c0\u6d4b\u3001\u591a\u53d1\u5c04\u4e0b\u7684\u5192\u9669\u4e0e\u8d44\u6e90\u51b2\u7a81\u3002</p>"}]}